# ─────────────────────────────────────────────────────────────
# PulseAI Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Groq API Keys (comma-separated for rotation)
GROQ_API_KEYS=key1,key2,key3

# Model configuration
GROQ_TEST_MODEL=llama-3.1-8b-instant
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# Set to "true" to use the 70B model for all summaries (expensive)
GROQ_USE_70B=false

# Demo review summary interval in seconds
DEMO_REVIEW_SUMMARY_INTERVAL_SECONDS=90

# Server port (default: 3001)
PORT=3001
